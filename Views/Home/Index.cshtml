@{
    ViewData["Title"] = "Accueil";
}

<!-- Section Héros -->
<div class="hero text-center">
    <h1>🎮 Bienvenue sur GameStore</h1>
    <p>Le meilleur endroit pour acheter et commander vos jeux vidéo préférés.</p>
    
    <!-- Ajout de l'image principale -->
    <img src="~/images/ca-times.brightspotcdn.jpg" class="hero-img" alt="Joueur enthousiaste" asp-append-version="true">

    <a class="btn btn-primary btn-lg mt-3" asp-controller="Products" asp-action="Index">Parcourir les jeux</a>
</div>

<!-- Section Jeux en vedette -->
<div class="container mt-5">
    <h2 class="text-center text-light">🔥 Jeux en vedette</h2>
    <div class="row justify-content-center">
        
        <!-- CyberStrike 2077 -->
        <div class="col-md-4">
            <div class="card game-card">
                <img src="~/images/cyberpunk2077.jpg" class="card-img-top game-img" alt="CyberStrike 2077">
                <div class="card-body text-center">
                    <h5 class="card-title">CyberStrike 2077</h5>
                    <p class="card-text">$59,99 </p>
                    <a href="#" class="btn btn-warning">Acheter maintenant</a>
                </div>
            </div>
        </div>

        <!-- Warzone: Rebirth -->
        <div class="col-md-4">
            <div class="card game-card">
                <img src="~/images/warzone-rebirth.jpg" class="card-img-top game-img" alt="Warzone: Rebirth">
                <div class="card-body text-center">
                    <h5 class="card-title">Warzone: Rebirth</h5>
                    <p class="card-text">$49,99 </p>
                    <a href="#" class="btn btn-warning">Acheter maintenant</a>
                </div>
            </div>
        </div>
    </div>
</div>
