@{
    // C'est le titre qui s'affichera dans l’onglet du navigateur
    ViewData["Title"] = "Politique de confidentialité";
}

<div class="container mt-5 text-light">
    <!-- Titre principal de la page -->
    <h1 class="mb-4">@ViewData["Title"]</h1>

    <!-- Ici tu expliques ce que tu fais avec les infos de l’utilisateur -->
    <p>
        Cette application recueille uniquement les informations nécessaires à la création de votre compte, 
        à la gestion des commandes et à la sécurité de votre session.
    </p>

    <p>
        Vos données ne sont ni revendues ni partagées à des tiers. Elles sont stockées de manière sécurisée dans notre base de données.
    </p>

    <p>
        Vous avez le droit de demander la suppression ou la modification de vos informations personnelles en contactant un administrateur.
    </p>

    <p>
        En vous inscrivant et en utilisant l'application, vous acceptez notre politique de confidentialité.
    </p>

    <p class="text-muted mt-5">
        Dernière mise à jour : avril 2025
    </p>
</div>
