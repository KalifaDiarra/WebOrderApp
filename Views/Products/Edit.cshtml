@model WebOrderApp.Models.Product

<!-- Titre de la page -->
<h2>Modifier le produit</h2>

<!-- Formulaire pour modifier un produit existant -->
<form asp-action="Edit">

    <!-- Champ caché pour passer l'ID du produit (obligatoire pour savoir lequel on modifie) -->
    <input type="hidden" asp-for="Id" />

    <!-- Nom du produit -->
    <div class="form-group">
        <label asp-for="Name">Nom du produit</label>
        <input asp-for="Name" class="form-control" required />
    </div>

    <!-- Description (optionnelle, donc pas de required) -->
    <div class="form-group">
        <label asp-for="Description">Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <!-- Prix (type number avec step pour les décimales comme 9.99) -->
    <div class="form-group">
        <label asp-for="Price">Prix</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" required />
    </div>

    <!-- Bouton bleu pour enregistrer les changements -->
    <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>

    <!-- Bouton gris pour retourner à la liste des produits sans rien sauvegarder -->
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>
