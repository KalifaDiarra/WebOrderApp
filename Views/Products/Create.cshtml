@model WebOrderApp.Models.Product

<!-- Titre de la page -->
<h2>Créer un produit</h2>

<!-- Formulaire ASP.NET Core lié à l'action Create du contrôleur -->
<form asp-action="Create">

    <!-- Champ pour entrer le nom du produit -->
    <div class="form-group">
        <label asp-for="Name">Nom du produit</label>
        <input asp-for="Name" class="form-control" required />
    </div>

    <!-- Champ pour écrire une description du produit -->
    <div class="form-group">
        <label asp-for="Description">Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <!-- Champ pour le prix avec validation HTML (step=0.01 pour permettre les décimales) -->
    <div class="form-group">
        <label asp-for="Price">Prix</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" required />
    </div>

    <!-- Bouton pour envoyer le formulaire -->
    <button type="submit" class="btn btn-success">Créer</button>

    <!-- Lien de retour à la liste des produits -->
    <a asp-action="Index" class="btn btn-secondary">Retour à la liste</a>
</form>
