@model IEnumerable<WebOrderApp.Models.Order>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    // Titre de la page affiché dans l’onglet
    ViewData["Title"] = "Mes Commandes";

    // Vérifie si l'utilisateur est connecté (ça retourne true ou false)
    var isLoggedIn = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId") != null;
}

<!-- Titre principal -->
<h2 class="text-white">Liste des commandes</h2>

<!-- Bouton pour créer une nouvelle commande -->
<div class="mb-3">
    <a class="btn btn-success" asp-action="Create">
        <i class="fas fa-plus-circle"></i> Nouvelle commande
    </a>
</div>

<!-- Message s’il n’y a aucune commande -->
@if (!Model.Any())
{
    <div class="alert alert-warning text-center">
        🛒 Aucune commande trouvée.
    </div>
}
else
{
    <!-- Tableau qui affiche les commandes -->
    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Produit</th>

                <!-- Si l’utilisateur n’est pas connecté (admin par exemple), on montre aussi l’utilisateur -->
                @if (!isLoggedIn)
                {
                    <th>Utilisateur</th>
                }

                <th>Quantité</th>
                <th>Prix Total</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <!-- Nom du produit commandé (nullable donc on met ?) -->
                <td>@order.Product?.Name</td>

                <!-- Si pas connecté (ex: admin), on affiche le nom du client -->
                @if (!isLoggedIn)
                {
                    <td>@order.User?.FirstName</td>
                }

                <!-- Quantité, prix et date -->
                <td>@order.Quantity</td>
                <td>$@order.TotalPrice</td>
                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>

                <!-- Liens vers modification ou suppression -->
                <td>
                    <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-warning">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-danger">Supprimer</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
