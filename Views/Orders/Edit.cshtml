@model WebOrderApp.Models.Order

@{
    // Titre de la page (utilisé dans l'onglet du navigateur)
    ViewData["Title"] = "Modifier la commande";
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">Modifier la commande</h2>

    <!-- Formulaire d’édition d’une commande existante -->
    <form asp-action="Edit" method="post" class="border p-4 rounded shadow bg-light">
        @Html.AntiForgeryToken() <!-- Sécurité anti-CSRF -->

        <!-- ID de la commande (important pour retrouver l’élément à modifier) -->
        <input type="hidden" asp-for="Id" />

        <!-- On garde l'UserId sinon ça l’écraserait à null -->
        <input type="hidden" asp-for="UserId" />

        <!-- Dropdown pour choisir un produit -->
        <div class="mb-3">
            <label asp-for="ProductId" class="form-label">Produit :</label>
            <select asp-for="ProductId" class="form-select" asp-items="ViewBag.Products"></select>
            <span asp-validation-for="ProductId" class="text-danger"></span>
        </div>

        <!-- Champ pour modifier la quantité -->
        <div class="mb-3">
            <label asp-for="Quantity" class="form-label">Quantité :</label>
            <input asp-for="Quantity" class="form-control" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <!-- Date de commande modifiable (format date + heure) -->
        <div class="mb-3">
            <label asp-for="OrderDate" class="form-label">Date :</label>
            <input asp-for="OrderDate" type="datetime-local" class="form-control" />
            <span asp-validation-for="OrderDate" class="text-danger"></span>
        </div>

        <!-- Bouton de validation -->
        <button type="submit" class="btn btn-success">
            <i class="fas fa-save"></i> Enregistrer les modifications
        </button>

        <!-- Bouton retour à la liste des commandes -->
        <a asp-action="Index" class="btn btn-secondary ms-2">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </form>
</div>

<!-- Active la validation côté client -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
